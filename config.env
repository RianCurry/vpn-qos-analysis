# Konfigurasi ThinkPad (client)
PI_USER=raspian
PI_IP=192.168.11.106
# Path absolut ke sampler di Pi
SAMPLER_SCRIPT_PATH="/home/raspian/vpn-qos-analysis/collect_pi_metrics.sh"
# IP target
BASELINE_IP=192.168.11.106
WIREGUARD_IP=10.10.10.1
OPENVPN_IP=10.8.0.1

# Parameter pengujian
ITER=5
PING_COUNT=50
MTR_COUNT=10
SAMPLE_INTERVAL=1
DURATION_LIGHT=30
DURATION_MEDIUM=60
DURATION_HEAVY=60
P_LIGHT=1
P_MEDIUM=4
P_HEAVY=8

# Fitur tambahan
UDP_TEST=no
HTTP_TEST=yes
ENABLE_LONG_TEST=no
SLEEP_BETWEEN=2
SSH_PASS="1"

# (Opsional) Password SSH – jika diisi, tidak akan diminta
# SSH_PASS="password_anda"